# SUI RPC Endpoint
NEXT_PUBLIC_SUI_RPC=https://fullnode.mainnet.sui.io:443

# Vercel KV (Redis) — for OHLCV chart caching
# Add via: Vercel Dashboard > Storage > Create KV Database > Connect to project
# These are auto-injected by Vercel when you connect a KV store
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# Optional: Custom wallet config
# NEXT_PUBLIC_WALLET_PROJECT_ID=your_project_id
