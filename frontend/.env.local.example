# Momentum DEX graduation (auto pool creation)
ADMIN_WALLET_SECRET=          # Admin wallet private key (suiprivkey1... or hex)
MOMENTUM_PACKAGE_ID=          # Momentum mainnet package ID (set when available)
MOMENTUM_GLOBAL_CONFIG=       # Momentum GlobalConfig object ID

# Vercel Cron auth (optional — protects /api/cron/* routes)
CRON_SECRET=
