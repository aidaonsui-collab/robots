# Stripe Issuing
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Vercel KV (already configured)
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# Backend URLs
ODYSSEY_BACKEND_URL=
MOVE_COMPILER_URL=

# Upstash Redis (for Railway agent worker communication)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# MiniMax LLM
MINIMAX_API_KEY=

# Web Search (optional — agent uses DuckDuckGo as free fallback)
